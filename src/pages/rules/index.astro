---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const chapters = await getCollection('rules');
chapters.sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
---

<Layout title="Rules">
  <h1>Rules of Nippon</h1>
  <p>Savage Bushido is built on the Savage Worlds Adventure Edition rules. The chapters below cover everything specific to the world of Nippon.</p>

  <ul class="chapter-list">
    {chapters.map(chapter => (
      <li>
        <a href={`/rules/${chapter.id}`}>
          <span class="chapter-num">
            {chapter.data.label || `Chapter ${chapter.data.chapterNumber}`}
          </span>
          <span class="chapter-title">{chapter.data.title}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="playtest-banner">
    <p>Running a playtest session? <a href="https://docs.google.com/forms/d/e/1FAIpQLSej4cuMaQM1e78kpwGZSaEtTIs0PfL57fetoNx30h5lTxhk3w/viewform" target="_blank">Submit your feedback →</a></p>
  </div>
</Layout>

<style>
  h1 {
    font-size: 2rem;
    color: #8b1a1a;
    border-bottom: 1px solid #c4a96b;
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }

  p {
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .chapter-list {
    list-style: none;
    padding: 0;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .chapter-list a {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.8rem 1rem;
    background: #ede5cc;
    border: 1px solid #c4a96b;
    border-radius: 4px;

cat > ~/Desktop/savage-bushido/src/pages/rules/index.astro << 'ENDOFFILE'
---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const chapters = await getCollection('rules');
chapters.sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
---

<Layout title="Rules">
  <h1>Rules of Nippon</h1>
  <p>Savage Bushido is built on the Savage Worlds Adventure Edition rules. The chapters below cover everything specific to the world of Nippon.</p>

  <ul class="chapter-list">
    {chapters.map(chapter => (
      <li>
        <a href={`/rules/${chapter.id}`}>
          <span class="chapter-num">
            {chapter.data.label || `Chapter ${chapter.data.chapterNumber}`}
          </span>
          <span class="chapter-title">{chapter.data.title}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="playtest-banner">
    <p>Running a playtest session? <a href="https://docs.google.com/forms/d/e/1FAIpQLSej4cuMaQM1e78kpwGZSaEtTIs0PfL57fetoNx30h5lTxhk3w/viewform" target="_blank">Submit your feedback →</a></p>
  </div>
</Layout>

<style>
  h1 {
    font-size: 2rem;
    color: #8b1a1a;
    border-bottom: 1px solid #c4a96b;
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }

  p {
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .chapter-list {
    list-style: none;
    padding: 0;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .chapter-list a {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.8rem 1rem;
    background: #ede5cc;
    border: 1px solid #c4a96b;
    border-radius: 4px;
    text-decoration: none;
    color: #1a1208;
    transition: background 0.15s;
  }

  .chapter-list a:hover {
    background: #e0d5b8;
  }

  .chapter-num {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #7a6040;
    white-space: nowrap;
    min-width: 7rem;
    flex-shrink: 0;
  }

  .chapter-title {
    font-size: 1rem;
    color: #8b1a1a;
  }

  .playtest-banner {
    margin-top: 3rem;
    padding: 1rem 1.5rem;
    background: #ede5cc;
    border: 1px solid #c4a96b;
    border-left: 4px solid #8b1a1a;
    border-radius: 4px;
    font-size: 0.9rem;
    color: #3d2b10;
  }

  .playtest-banner a {
    color: #8b1a1a;
    font-weight: bold;
    text-decoration: none;
  }

  .playtest-banner a:hover {
    color: #b8902a;
  }
</style>
