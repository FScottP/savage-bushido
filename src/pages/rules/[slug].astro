---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const chapters = await getCollection('rules');
  chapters.sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);

  return chapters.map((chapter, index) => ({
    params: { slug: chapter.id },
    props: {
      chapter,
      prev: index > 0 ? chapters[index - 1] : null,
      next: index < chapters.length - 1 ? chapters[index + 1] : null,
    },
  }));
}

const { chapter, prev, next } = Astro.props;
const { Content } = await render(chapter);
const label = chapter.data.label || `Chapter ${chapter.data.chapterNumber}`;
---

<Layout title={`${label}: ${chapter.data.title}`}>

  {chapter.data.image && (
    <div class="chapter-hero">
      <img src={chapter.data.image} alt={chapter.data.title} class="chapter-hero-img" />
      <div class="chapter-hero-overlay">
        <div class="chapter-hero-content">
          <p class="chapter-label">{label}</p>
          <h1>{chapter.data.title}</h1>
          {chapter.data.description && <p class="description">{chapter.data.description}</p>}
        </div>
      </div>
    </div>
  )}

  {!chapter.data.image && (
    <div class="chapter-header-plain">
      <p class="chapter-label">{label}</p>
      <h1>{chapter.data.title}</h1>
      {chapter.data.description && <p class="description">{chapter.data.description}</p>}
    </div>
  )}

  <div class="chapter-body">
    <p class="breadcrumb"><a href="/rules">← All Chapters</a></p>

    <div class="content">
      <Content />
    </div>

    <nav class="chapter-nav">
      <div class="nav-prev">
        {prev && (
          <a href={`/rules/${prev.id}`}>
            <span class="nav-label">← Previous</span>
            <span class="nav-title">{prev.data.label || `Chapter ${prev.data.chapterNumber}`}: {prev.data.title}</span>
          </a>
        )}
      </div>
      <div class="nav-next">
        {next && (
          <a href={`/rules/${next.id}`}>
            <span class="nav-label">Next →</span>
            <span class="nav-title">{next.data.label || `Chapter ${next.data.chapterNumber}`}: {next.data.title}</span>
          </a>
        )}
      </div>
    </nav>
  </div>

</Layout>

<style>
  /* Hero image header */
  .chapter-hero {
    position: relative;
    width: 100%;
    height: 280px;
    overflow: hidden;
  }

  .chapter-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .chapter-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(26, 18, 8, 0.92) 0%,
      rgba(26, 18, 8, 0.7) 55%,
      rgba(26, 18, 8, 0.3) 100%
    );
    display: flex;
    align-items: flex-end;
  }

  .chapter-hero-content {
    padding: 2rem 2.5rem;
    max-width: 700px;
  }

  .chapter-hero-content .chapter-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #c4a96b;
    margin-bottom: 0.4rem;
  }

  .chapter-hero-content h1 {
    font-family: Georgia, serif;
    font-size: 2.2rem;
    color: #f5f0e3;
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
    border: none;
    padding: 0;
  }

  .chapter-hero-content .description {
    font-style: italic;
    color: #c4a96b;
    font-size: 0.95rem;
    margin: 0;
    opacity: 0.9;
  }

  /* Plain header (fallback if no image) */
  .chapter-header-plain {
    background: #1a1208;
    padding: 2.5rem 2.5rem 2rem;
  }

  .chapter-header-plain .chapter-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #c4a96b;
    margin-bottom: 0.4rem;
  }

  .chapter-header-plain h1 {
    font-family: Georgia, serif;
    font-size: 2.2rem;
    color: #f5f0e3;
    margin: 0 0 0.5rem 0;
    border: none;
    padding: 0;
  }

  .chapter-header-plain .description {
    font-style: italic;
    color: #c4a96b;
    font-size: 0.95rem;
    margin: 0;
  }

  /* Body content */
  .chapter-body {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .breadcrumb {
    font-size: 0.85rem;
    margin-bottom: 2rem;
    color: #7a6040;
  }

  .breadcrumb a {
    color: #7a6040;
    text-decoration: none;
  }

  .breadcrumb a:hover { color: #8b1a1a; }

  /* Content styles */
  .content h2 {
    color: #8b1a1a;
    border-bottom: 1px solid #c4a96b;
    padding-bottom: 0.3rem;
    margin-top: 2.5rem;
    font-family: Georgia, serif;
  }

  .content h3 {
    color: #3d2b10;
    margin-top: 1.5rem;
    font-family: Georgia, serif;
  }

  .content h4 {
    color: #3d2b10;
    margin-top: 1.2rem;
    font-style: italic;
  }

  .content p {
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .content th {
    background: #3d2b10;
    color: #f5f0e3;
    padding: 0.5rem 0.75rem;
    text-align: left;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .content td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid #e0d5b8;
    vertical-align: top;
  }

  .content tr:nth-child(even) td { background: #f0ead8; }

  .content ul, .content ol {
    padding-left: 1.5rem;
    margin: 1rem 0;
  }

  .content li {
    margin-bottom: 0.4rem;
    line-height: 1.6;
  }

  .content strong { color: #3d2b10; }

  .content em { color: #5a4020; }

  .content hr {
    border: none;
    border-top: 1px solid #c4a96b;
    margin: 2rem 0;
  }

  .content blockquote {
    border-left: 3px solid #c4a96b;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #5a4020;
    font-style: italic;
  }

  /* Prev/Next nav */
  .chapter-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #c4a96b;
  }

  .nav-prev, .nav-next { display: flex; }
  .nav-next { justify-content: flex-end; text-align: right; }

  .chapter-nav a {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    padding: 0.75rem 1rem;
    background: #ede5cc;
    border: 1px solid #c4a96b;
    border-radius: 4px;
    transition: background 0.15s;
    max-width: 100%;
  }

  .chapter-nav a:hover { background: #e0d5b8; }

  .nav-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #7a6040;
  }

  .nav-title {
    font-size: 0.9rem;
    color: #8b1a1a;
  }

  /* Override Layout main padding */
  :global(main) { padding: 0 !important; }

  @media (max-width: 600px) {
    .chapter-hero { height: 200px; }
    .chapter-hero-content h1 { font-size: 1.6rem; }
    .chapter-nav { grid-template-columns: 1fr; }
  }
</style>
