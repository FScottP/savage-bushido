---
const { title = "Savage Bushido" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Savage Bushido</title>
  </head>
  <body>
    <nav>
      <a href="/" class="site-title">武士道 Savage Bushido</a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/rules">Rules</a>
		<a href="/tools">Tools</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
  <p>Savage Bushido is an independent setting for Savage Worlds Adventure Edition.</p>
  <p><a href="https://docs.google.com/forms/d/e/1FAIpQLSej4cuMaQM1e78kpwGZSaEtTIs0PfL57fetoNx30h5lTxhk3w/viewform" target="_blank" class="feedback-link">Submit Playtest Feedback</a></p>
  <p class="copyright">© 2025 F. Scott Pfeiffer. All rights reserved. This game references the Savage Worlds game system, available from Pinnacle Entertainment Group at <a href="https://www.peginc.com" target="_blank">www.peginc.com</a>. Savage Worlds and all associated logos and trademarks are copyrights of Pinnacle Entertainment Group.</p>
</footer>
  </body>
</html>

<style>
  html, body {
    margin: 0;
    padding: 0;
    font-family: Georgia, serif;
    background: #f5f0e3;
    color: #1a1208;
  }

  /* ── Nav ── */
  nav {
    background: #1a1208;
    color: #f5f0e3;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .site-title {
    color: #c4a96b;
    text-decoration: none;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: #f5f0e3;
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .nav-links a:hover {
    opacity: 1;
    color: #c4a96b;
  }

  /* ── Main content ── */
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  h1 {
    font-size: 2rem;
    color: #8b1a1a;
    border-bottom: 1px solid #c4a96b;
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  p {
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  a {
    color: #8b1a1a;
  }

  /* ── Footer ── */
  footer {
    border-top: 1px solid #c4a96b;
    text-align: center;
    padding: 2rem;
    font-size: 0.85rem;
    color: #7a6040;
    margin-top: 4rem;
	.copyright {
  font-size: 0.75rem;
  color: #5a4830;
  margin-top: 0.5rem;
  line-height: 1.6;
  .feedback-link {
  color: #c4a96b;
  font-size: 0.85rem;
  text-decoration: none;
}

.feedback-link:hover {
  color: #f5f0e3;
}
}

.copyright a {
  color: #7a6040;
}
  }
</style>
