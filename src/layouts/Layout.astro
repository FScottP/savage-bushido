---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Savage Bushido</title>
  </head>
  <body>
    <nav>
      <a href="/" class="site-title">武士道 Savage Bushido</a>
     <div class="nav-links">
  <a href="/">Home</a>
