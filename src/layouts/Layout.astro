</html>

<style>
  html, body {
    margin: 0;
    padding: 0;
    font-family: Georgia, serif;
    background: #f5f0e3;
    color: #1a1208;
  }

  /* ── Nav ── */
  nav {
    background: #1a1208;
    color: #f5f0e3;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .site-title {
    color: #c4a96b;
    text-decoration: none;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: #f5f0e3;
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .nav-links a:hover {
    opacity: 1;
    color: #c4a96b;
  }

  /* ── Main content ── */
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  h1 {
    font-size: 2rem;
    color: #8b1a1a;
    border-bottom: 1px solid #c4a96b;
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  p {
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  a {
    color: #8b1a1a;
  }
  /* Dropdown */
.nav-dropdown {
  position: relative;
}

.nav-dropdown > a {
  cursor: pointer;
}

.dropdown-menu {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  background: #1a1208;
  border: 1px solid #c4a96b;
  border-top: none;
  min-width: 220px;
  z-index: 200;
  padding: 0.5rem 0;
}

.nav-dropdown:hover .dropdown-menu {
  display: block;
}

.dropdown-menu a {
  display: block;
  padding: 0.4rem 1rem;
  color: #f5f0e3 !important;
  font-size: 0.8rem;
  text-decoration: none;
  opacity: 0.85;
  letter-spacing: 0.03em;
  text-transform: none !important;
}

.dropdown-menu a:hover {
  opacity: 1;
  color: #c4a96b !important;
  background: rgba(255,255,255,0.05);
}

.dropdown-section {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #c4a96b;
  padding: 0.6rem 1rem 0.3rem;
  border-top: 1px solid rgba(196,169,107,0.3);
}

.dropdown-section:first-child {
  border-top: none;
}

  /* ── Footer ── */
  footer {
    border-top: 1px solid #c4a96b;
    text-align: center;
    padding: 2rem;
    font-size: 0.85rem;
    color: #7a6040;
    margin-top: 4rem;
	.copyright {
  font-size: 0.75rem;
  color: #5a4830;
  margin-top: 0.5rem;
  line-height: 1.6;
  .feedback-link {
  color: #c4a96b;
  font-size: 0.85rem;
  text-decoration: none;
}

.feedback-link:hover {
  color: #f5f0e3;
}
}

.copyright a {
  color: #7a6040;
}
  }
</style>
